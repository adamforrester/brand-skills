  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "inquirer": "^13.4.2",
    "ora": "^9.4.0",
    "yaml": "^2.7.1"
  }
}
