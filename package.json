  "description": "AI-agent skills + CLI for extracting structured brand packages (.brand/) from client assets — Figma, live website, social, brand-guide PDFs. Pairs with the design.md spec.",
  "type": "module",
  "bin": {
    "brand-cli": "./cli/bin/brand-cli.js"
  },
  "files": [
